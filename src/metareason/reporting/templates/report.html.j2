<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>

    <script>{{ chartjs_source }}</script>
    <script>{{ chartjs_annotation_source }}</script>
    <script>{{ chartjs_matrix_source }}</script>

    <style>
        /* Base */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #f8fafc; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
        .card { background: white; border-radius: 12px; box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1); border: 1px solid #e2e8f0; }
        .code-pill { font-family: 'Monaco', 'Consolas', monospace; font-size: 0.85em; background-color: #f1f5f9; padding: 2px 6px; border-radius: 4px; color: #475569; }

        /* Layout */
        .flex { display: flex; }
        .flex-col { flex-direction: column; }
        .flex-grow { flex-grow: 1; }
        .items-center { align-items: center; }
        .items-end { align-items: flex-end; }
        .justify-between { justify-content: space-between; }
        .justify-center { justify-content: center; }
        .gap-2 { gap: 0.5rem; }
        .gap-3 { gap: 0.75rem; }
        .gap-4 { gap: 1rem; }
        .gap-6 { gap: 1.5rem; }
        .grid { display: grid; }
        .grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
        .grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .relative { position: relative; }
        .overflow-hidden { overflow: hidden; }
        .overflow-x-auto { overflow-x: auto; }

        /* Spacing */
        .p-5 { padding: 1.25rem; }
        .p-6 { padding: 1.5rem; }
        .p-8 { padding: 2rem; }
        .px-1 { padding-left: 0.25rem; padding-right: 0.25rem; }
        .px-2 { padding-left: 0.5rem; padding-right: 0.5rem; }
        .px-3 { padding-left: 0.75rem; padding-right: 0.75rem; }
        .px-4 { padding-left: 1rem; padding-right: 1rem; }
        .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
        .py-0\.5 { padding-top: 0.125rem; padding-bottom: 0.125rem; }
        .py-1 { padding-top: 0.25rem; padding-bottom: 0.25rem; }
        .py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
        .py-3 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
        .py-4 { padding-top: 1rem; padding-bottom: 1rem; }
        .mb-1 { margin-bottom: 0.25rem; }
        .mb-2 { margin-bottom: 0.5rem; }
        .mb-3 { margin-bottom: 0.75rem; }
        .mb-4 { margin-bottom: 1rem; }
        .mb-8 { margin-bottom: 2rem; }
        .mt-1 { margin-top: 0.25rem; }
        .mt-4 { margin-top: 1rem; }
        .mt-12 { margin-top: 3rem; }
        .ml-2 { margin-left: 0.5rem; }
        .mx-auto { margin-left: auto; margin-right: auto; }
        .pb-8 { padding-bottom: 2rem; }

        /* Typography */
        .text-xs { font-size: 0.75rem; line-height: 1rem; }
        .text-sm { font-size: 0.875rem; line-height: 1.25rem; }
        .text-lg { font-size: 1.125rem; line-height: 1.75rem; }
        .text-xl { font-size: 1.25rem; line-height: 1.75rem; }
        .text-2xl { font-size: 1.5rem; line-height: 2rem; }
        .text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
        .font-bold { font-weight: 700; }
        .font-semibold { font-weight: 600; }
        .font-medium { font-weight: 500; }
        .font-mono { font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace; }
        .uppercase { text-transform: uppercase; }
        .tracking-wider { letter-spacing: 0.05em; }
        .tracking-wide { letter-spacing: 0.025em; }
        .text-left { text-align: left; }
        .text-center { text-align: center; }
        .antialiased { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

        /* Colors */
        .text-white { color: #ffffff; }
        .text-slate-400 { color: #94a3b8; }
        .text-slate-500 { color: #64748b; }
        .text-slate-600 { color: #475569; }
        .text-slate-700 { color: #334155; }
        .text-slate-800 { color: #1e293b; }
        .text-slate-900 { color: #0f172a; }
        .text-indigo-600 { color: #4f46e5; }
        .text-indigo-700 { color: #4338ca; }
        .text-indigo-100 { color: #e0e7ff; }
        .text-blue-600 { color: #2563eb; }
        .text-green-800 { color: #166534; }
        .text-amber-400 { color: #fbbf24; }
        .text-amber-600 { color: #d97706; }
        .text-amber-800 { color: #92400e; }
        .bg-white { background-color: #ffffff; }
        .bg-slate-50 { background-color: #f8fafc; }
        .bg-slate-900 { background-color: #0f172a; }
        .bg-blue-50 { background-color: #eff6ff; }
        .bg-slate-100 { background-color: #f1f5f9; }
        .bg-green-100 { background-color: #dcfce7; }
        .bg-indigo-50 { background-color: #eef2ff; }
        .bg-amber-50 { background-color: #fffbeb; }
        .bg-white\/20 { background-color: rgba(255, 255, 255, 0.2); }
        .bg-white\/10 { background-color: rgba(255, 255, 255, 0.1); }
        .bg-gradient-to-r { background-image: linear-gradient(to right, var(--tw-gradient-from), var(--tw-gradient-to)); }
        .from-indigo-600 { --tw-gradient-from: #4f46e5; --tw-gradient-to: #4f46e5; }
        .to-blue-500 { --tw-gradient-to: #3b82f6; }

        /* Borders */
        .border { border-width: 1px; border-style: solid; border-color: #e2e8f0; }
        .border-b { border-bottom-width: 1px; border-bottom-style: solid; border-bottom-color: #e2e8f0; }
        .border-l-4 { border-left-width: 4px; border-left-style: solid; }
        .border-slate-200 { border-color: #e2e8f0; }
        .border-amber-100 { border-color: #fef3c7; }
        .border-l-blue-500 { border-left-color: #3b82f6; }
        .border-l-indigo-500 { border-left-color: #6366f1; }
        .border-l-purple-500 { border-left-color: #a855f7; }
        .border-l-slate-400 { border-left-color: #94a3b8; }
        .rounded { border-radius: 0.25rem; }
        .rounded-lg { border-radius: 0.5rem; }
        .rounded-xl { border-radius: 0.75rem; }

        /* Sizing */
        .w-4 { width: 1rem; }
        .w-10 { width: 2.5rem; }
        .w-16 { width: 4rem; }
        .w-32 { width: 8rem; }
        .w-full { width: 100%; }
        .h-4 { height: 1rem; }
        .h-10 { height: 2.5rem; }
        .h-64 { height: 16rem; }
        .max-w-7xl { max-width: 80rem; }

        /* Effects */
        .shadow-lg { box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1); }
        .opacity-90 { opacity: 0.9; }
        .transition { transition-property: color, background-color, border-color, text-decoration-color, fill, stroke, opacity, box-shadow, transform, filter, backdrop-filter; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }

        /* Table */
        .divide-y > * + * { border-top-width: 1px; border-top-style: solid; }
        .divide-slate-100 > * + * { border-top-color: #f1f5f9; }

        /* Hover */
        .hover\:bg-slate-700:hover { background-color: #334155; }
        .hover\:bg-slate-50:hover { background-color: #f8fafc; }

        /* Responsive */
        @media (min-width: 768px) {
            .md\:flex-row { flex-direction: row; }
            .md\:items-center { align-items: center; }
            .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .md\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
            .md\:p-8 { padding: 2rem; }
            .md\:p-10 { padding: 2.5rem; }
            .md\:text-2xl { font-size: 1.5rem; line-height: 2rem; }
        }
        @media (min-width: 1024px) {
            .lg\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        }

        /* Help tooltip */
        .help-btn { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border-radius: 50%; background: #e2e8f0; color: #64748b; font-size: 12px; font-weight: 600; cursor: pointer; border: none; line-height: 1; margin-left: 6px; position: relative; flex-shrink: 0; }
        .help-btn:hover { background: #cbd5e1; color: #334155; }
        .help-popup { display: none; position: absolute; top: 28px; right: 0; width: 320px; background: #1e293b; color: #e2e8f0; padding: 14px 16px; border-radius: 8px; font-size: 12px; line-height: 1.55; font-weight: 400; z-index: 50; box-shadow: 0 10px 25px rgba(0,0,0,0.25); }
        .help-popup::before { content: ''; position: absolute; top: -6px; right: 8px; width: 12px; height: 12px; background: #1e293b; transform: rotate(45deg); }
        .help-popup strong { color: #fff; }
        .help-btn.active .help-popup { display: block; }

        /* Print */
        @media print {
            body { background-color: white; }
            .card { box-shadow: none; border: 1px solid #ddd; break-inside: avoid; margin-bottom: 20px; }
            .no-print { display: none; }
        }
    </style>
</head>
<body class="text-slate-800 antialiased p-6 md:p-10 max-w-7xl mx-auto">

    <!-- Header -->
    <header class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div>
            <div class="text-xs font-bold tracking-wider text-indigo-600 uppercase mb-1">MetaReason Evaluation Report</div>
            <h1 class="text-3xl font-bold text-slate-900">{{ spec_id }}</h1>
            <p class="text-slate-500 text-sm mt-1">Generated: {{ timestamp }}</p>
        </div>
        <div class="flex gap-3">
            <div class="flex flex-col items-end px-4 py-2 bg-white rounded-lg border border-slate-200">
                <span class="text-xs text-slate-500 uppercase font-semibold">Variants</span>
                <span class="font-bold text-lg">{{ n_variants }}</span>
            </div>
            <div class="flex flex-col items-end px-4 py-2 bg-white rounded-lg border border-slate-200">
                <span class="text-xs text-slate-500 uppercase font-semibold">Oracles</span>
                <span class="font-bold text-lg">{{ n_oracles }}</span>
            </div>
            <button onclick="window.print()" class="no-print px-4 py-2 bg-slate-900 text-white rounded-lg hover:bg-slate-700 transition font-medium text-sm">
                Print Report
            </button>
        </div>
    </header>

    <!-- Configuration Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Model Under Test -->
        <div class="card p-6">
            <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wide mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                Model Under Test
            </h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="text-xs text-slate-500 bg-slate-50 uppercase border-b">
                        <tr>
                            <th class="px-3 py-2">Stage</th>
                            <th class="px-3 py-2">Model</th>
                            <th class="px-3 py-2">Adapter</th>
                            <th class="px-3 py-2">Temp</th>
                            <th class="px-3 py-2">Top-P</th>
                            <th class="px-3 py-2">Max Tok</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stage in pipeline_stages %}
                        <tr>
                            <td class="px-3 py-3 font-mono text-slate-400">{{ loop.index }}</td>
                            <td class="px-3 py-3 font-medium text-indigo-700">{{ stage.model }}</td>
                            <td class="px-3 py-3">{{ stage.adapter }}</td>
                            <td class="px-3 py-3">{{ stage.temperature }}</td>
                            <td class="px-3 py-3">{{ stage.top_p }}</td>
                            <td class="px-3 py-3">{{ stage.max_tokens }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Oracle Judges -->
        <div class="card p-6">
            <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wide mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Oracle Judges
            </h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="text-xs text-slate-500 bg-slate-50 uppercase border-b">
                        <tr>
                            <th class="px-3 py-2">Oracle Name</th>
                            <th class="px-3 py-2">Type</th>
                            <th class="px-3 py-2">Model</th>
                            <th class="px-3 py-2">Adapter</th>
                            <th class="px-3 py-2">Temp</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for name, cfg in oracle_configs.items() %}
                        <tr>
                            <td class="px-3 py-3 font-medium">{{ name }}</td>
                            <td class="px-3 py-3"><span class="bg-green-100 text-green-800 px-2 py-0.5 rounded text-xs">{{ cfg.type }}</span></td>
                            <td class="px-3 py-3">{{ cfg.model }}</td>
                            <td class="px-3 py-3">{{ cfg.adapter }}</td>
                            <td class="px-3 py-3">{{ cfg.temperature }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    {% for oracle_name, analysis in oracle_analyses.items() %}
    <!-- Confidence Assessment: {{ oracle_name }} -->
    <div class="bg-gradient-to-r from-indigo-600 to-blue-500 rounded-xl p-6 md:p-8 text-white shadow-lg mb-8">
        <h2 class="text-xl md:text-2xl font-bold mb-2">Confidence Assessment</h2>
        <p class="text-indigo-100 text-lg opacity-90">
            We are <span class="font-bold text-white bg-white/20 px-1 rounded">{{ hdi_pct }}% confident</span>
            the true {{ oracle_name }} score of
            <span class="font-mono text-sm bg-white/10 px-1 rounded">{{ primary_model }}</span> outputs is between
            <strong>{{ analysis.hdi_lower | round(2) }}</strong> and <strong>{{ analysis.hdi_upper | round(2) }}</strong>.
        </p>
    </div>

    <!-- Metrics Row -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="card p-5 border-l-4 border-l-blue-500">
            <div class="text-slate-500 text-xs uppercase font-semibold mb-1">Mean Score</div>
            <div class="text-3xl font-bold text-slate-800">{{ analysis.population_mean | round(3) }}</div>
            <div class="text-xs text-slate-400 mt-1">Model Output</div>
        </div>
        <div class="card p-5 border-l-4 border-l-indigo-500">
            <div class="text-slate-500 text-xs uppercase font-semibold mb-1">Median Score</div>
            <div class="text-3xl font-bold text-slate-800">{{ analysis.population_median | round(3) }}</div>
            <div class="text-xs text-slate-400 mt-1">Model Output</div>
        </div>
        <div class="card p-5 border-l-4 border-l-purple-500">
            <div class="text-slate-500 text-xs uppercase font-semibold mb-1">{{ hdi_pct }}% HDI</div>
            <div class="text-2xl font-bold text-slate-800">{{ analysis.hdi_lower | round(2) }} &ndash; {{ analysis.hdi_upper | round(2) }}</div>
            <div class="text-xs text-slate-400 mt-1">Highest Density Interval</div>
        </div>
        <div class="card p-5 border-l-4 border-l-slate-400 bg-slate-50">
            <div class="text-slate-500 text-xs uppercase font-semibold mb-1">Judge Noise</div>
            <div class="text-3xl font-bold text-slate-800">{{ analysis.oracle_noise_mean | round(2) }}</div>
            <div class="text-xs text-slate-400 mt-1">{{ oracle_configs[oracle_name].model }}</div>
        </div>
    </section>

    <!-- Charts Grid -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Posterior Distribution -->
        <div class="card p-6">
            <div class="flex justify-between items-center mb-4">
                <div class="flex items-center">
                    <h3 class="font-bold text-slate-700">Estimated True Quality</h3>
                    <button class="help-btn" onclick="this.classList.toggle('active')">?<div class="help-popup"><strong>What is this?</strong> This curve shows our best estimate of the model's true quality after accounting for judge measurement error. The peak is the most likely quality score. The <strong>shaded region</strong> is the {{ hdi_pct }}% High Density Interval (HDI) &mdash; we are {{ hdi_pct }}% confident the true quality falls within this range. A narrower curve means more certainty; a wider curve means we need more data.</div></button>
                </div>
                <span class="text-xs font-mono bg-blue-50 text-blue-600 px-2 py-1 rounded">Bayesian Posterior</span>
            </div>
            <div class="relative h-64 w-full">
                <canvas id="posteriorChart-{{ oracle_name }}"></canvas>
            </div>
            <div class="mt-4 text-center text-xs text-slate-500">
                The shaded area represents the {{ hdi_pct }}% High Density Interval [{{ analysis.hdi_lower | round(2) }}, {{ analysis.hdi_upper | round(2) }}].
            </div>
        </div>

        <!-- Score Distribution -->
        <div class="card p-6">
            <div class="flex justify-between items-center mb-4">
                <div class="flex items-center">
                    <h3 class="font-bold text-slate-700">Observed Score Distribution</h3>
                    <button class="help-btn" onclick="this.classList.toggle('active')">?<div class="help-popup"><strong>What is this?</strong> A histogram of the raw scores the judge assigned across all {{ n_variants }} evaluations. The red dashed line marks the mean score. <strong>How to read it:</strong> If most bars cluster at 4-5, the model performs consistently well. A wide spread across 1-5 suggests high variability &mdash; check the parameter effects chart to see what drives it.</div></button>
                </div>
                <span class="text-xs font-mono bg-slate-100 text-slate-600 px-2 py-1 rounded">n={{ n_variants }}</span>
            </div>
            <div class="relative h-64 w-full">
                <canvas id="histogramChart-{{ oracle_name }}"></canvas>
            </div>
            <div class="mt-4 text-center text-xs text-slate-500">
                Frequency of scores assigned by {{ oracle_name }}.
            </div>
        </div>

    </section>

    <!-- Score by Parameter (only when no interaction heatmap) -->
    {% if chart_data[oracle_name].has_breakdowns and not chart_data[oracle_name].has_interaction %}
    <section class="mb-8">
        <div class="card p-6">
            <div class="flex justify-between items-center mb-4">
                <div class="flex items-center">
                    <h3 class="font-bold text-slate-700">Score by Parameter</h3>
                    <button class="help-btn" onclick="this.classList.toggle('active')">?<div class="help-popup"><strong>What is this?</strong> Mean score for each value of the categorical parameter. Taller bars = higher average scores. The number above each bar is the count of evaluations in that group. <strong>How to read it:</strong> Compare bar heights to see which parameter values produce the best or worst results.</div></button>
                </div>
            </div>
            {% for bd in chart_data[oracle_name].category_breakdowns %}
            <div class="{% if not loop.first %}mt-4 pt-4 border-b{% endif %}">
                <div class="text-xs text-slate-500 uppercase font-semibold mb-2">{{ bd.axis_name }}</div>
                <div class="relative" style="height: 180px;">
                    <canvas id="breakdownChart-{{ oracle_name }}-{{ loop.index0 }}"></canvas>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    <!-- Parameter Interactions -->
    {% if chart_data[oracle_name].has_interaction %}
    <section class="mb-8">
        <div class="card p-6">
            <div class="flex justify-between items-center mb-4">
                <div class="flex items-center">
                    <h3 class="font-bold text-slate-700">Parameter Interactions</h3>
                    <button class="help-btn" onclick="this.classList.toggle('active')">?<div class="help-popup"><strong>What is this?</strong> Mean scores for every combination of the two most impactful categorical parameters. Green = higher scores, red = lower scores. <strong>How to read it:</strong> Look for cells that stand out &mdash; these are parameter combinations that produce notably better or worse results.</div></button>
                </div>
            </div>
            <div class="relative w-full" style="height: {{ chart_data[oracle_name].interaction.row_values | length * 90 + 80 }}px;">
                <canvas id="interactionChart-{{ oracle_name }}"></canvas>
            </div>
            <!-- Gradient legend -->
            <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 12px;">
                <span style="font-size: 11px; color: #94a3b8;">1.0</span>
                <div style="width: 200px; height: 10px; border-radius: 5px; background: linear-gradient(to right, #fca5a5, #fde68a, #86efac);"></div>
                <span style="font-size: 11px; color: #94a3b8;">5.0</span>
            </div>
            <div style="text-align: center; margin-top: 6px; font-size: 11px; color: #94a3b8;">
                x-axis: <strong style="color: #64748b;">{{ chart_data[oracle_name].interaction.col_axis }}</strong>
                &nbsp;&middot;&nbsp;
                y-axis: <strong style="color: #64748b;">{{ chart_data[oracle_name].interaction.row_axis }}</strong>
            </div>
        </div>
    </section>
    {% endif %}

    {% endfor %}

    <footer class="mt-12 text-center text-xs text-slate-400 pb-8">
        MetaReason Report Generator &middot; {{ timestamp[:4] }}
    </footer>

    <!-- Chart.js Configuration -->
    <script>
    // Close help tooltips when clicking outside
    document.addEventListener('click', function(e) {
        if (!e.target.classList.contains('help-btn')) {
            document.querySelectorAll('.help-btn.active').forEach(function(btn) {
                btn.classList.remove('active');
            });
        }
    });

    (function() {
        const chartData = {{ chart_data | tojson }};

        const commonScatterOpts = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: {
                    type: 'linear',
                    grid: { display: false },
                    ticks: { callback: v => v.toFixed(1) }
                },
                y: {
                    grid: { color: '#f1f5f9' },
                    beginAtZero: true,
                    ticks: { display: false }
                }
            }
        };

        Object.keys(chartData).forEach(function(oracleName) {
            const d = chartData[oracleName];

            // --- Posterior Distribution ---
            const posteriorPoints = d.posterior_x.map((x, i) => ({x: x, y: d.posterior_y[i]}));
            new Chart(document.getElementById('posteriorChart-' + oracleName), {
                type: 'scatter',
                data: {
                    datasets: [{
                        data: posteriorPoints,
                        showLine: true,
                        borderColor: '#4f46e5',
                        borderWidth: 2,
                        fill: false,
                        pointRadius: 0,
                        tension: 0.3
                    }]
                },
                options: {
                    ...commonScatterOpts,
                    plugins: {
                        legend: { display: false },
                        annotation: {
                            annotations: {
                                hdiBox: {
                                    type: 'box',
                                    xMin: d.hdi_lower,
                                    xMax: d.hdi_upper,
                                    backgroundColor: 'rgba(79, 70, 229, 0.12)',
                                    borderWidth: 0
                                },
                                meanLine: {
                                    type: 'line',
                                    xMin: d.population_mean,
                                    xMax: d.population_mean,
                                    borderColor: '#ef4444',
                                    borderWidth: 1.5,
                                    borderDash: [5, 5],
                                    label: {
                                        display: true,
                                        content: 'Mean: ' + d.population_mean.toFixed(2),
                                        position: 'start',
                                        backgroundColor: 'rgba(239, 68, 68, 0.8)',
                                        font: { size: 10 }
                                    }
                                },
                                medianLine: {
                                    type: 'line',
                                    xMin: d.population_median,
                                    xMax: d.population_median,
                                    borderColor: '#f59e0b',
                                    borderWidth: 1.5,
                                    borderDash: [5, 5],
                                    label: {
                                        display: true,
                                        content: 'Median: ' + d.population_median.toFixed(2),
                                        position: 'end',
                                        backgroundColor: 'rgba(245, 158, 11, 0.8)',
                                        font: { size: 10 }
                                    }
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            type: 'linear',
                            grid: { display: false },
                            title: { display: true, text: 'Quality Score', font: { size: 12 } },
                            ticks: { callback: v => v.toFixed(1) }
                        },
                        y: {
                            grid: { color: '#f1f5f9' },
                            beginAtZero: true,
                            title: { display: true, text: 'Density', font: { size: 12 } },
                            ticks: { display: false }
                        }
                    }
                }
            });

            // --- Score Histogram ---
            new Chart(document.getElementById('histogramChart-' + oracleName), {
                type: 'bar',
                data: {
                    labels: d.histogram_labels,
                    datasets: [{
                        data: d.histogram_counts,
                        backgroundColor: '#94a3b8',
                        hoverBackgroundColor: '#4f46e5',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        annotation: {
                            annotations: {
                                meanLine: {
                                    type: 'line',
                                    xMin: d.score_mean - 1,
                                    xMax: d.score_mean - 1,
                                    borderColor: '#ef4444',
                                    borderWidth: 2,
                                    borderDash: [5, 5],
                                    label: {
                                        display: true,
                                        content: 'Mean: ' + d.score_mean.toFixed(2),
                                        position: 'start',
                                        backgroundColor: 'rgba(239, 68, 68, 0.8)',
                                        font: { size: 10 }
                                    }
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            title: { display: true, text: 'Score', font: { size: 12 } }
                        },
                        y: {
                            grid: { color: '#f1f5f9' },
                            beginAtZero: true,
                            title: { display: true, text: 'Count', font: { size: 12 } },
                            ticks: { stepSize: 1 }
                        }
                    }
                }
            });

            // --- Score by Parameter (category breakdowns) ---
            if (d.has_breakdowns) {
                var palette = ['#6366f1', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4', '#ec4899', '#84cc16'];
                d.category_breakdowns.forEach(function(bd, bi) {
                    var ctx = document.getElementById('breakdownChart-' + oracleName + '-' + bi);
                    if (!ctx) return;
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: bd.values,
                            datasets: [{
                                data: bd.means,
                                backgroundColor: bd.values.map(function(_, i) { return palette[i % palette.length]; }),
                                borderRadius: 4,
                                barPercentage: 0.7
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                annotation: {
                                    annotations: {
                                        overallMean: {
                                            type: 'line',
                                            yMin: d.score_mean,
                                            yMax: d.score_mean,
                                            borderColor: 'rgba(0,0,0,0.3)',
                                            borderWidth: 1.5,
                                            borderDash: [5, 5],
                                            label: {
                                                display: true,
                                                content: 'Overall: ' + d.score_mean.toFixed(2),
                                                position: 'end',
                                                backgroundColor: 'rgba(0,0,0,0.5)',
                                                font: { size: 10 }
                                            }
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: { grid: { display: false } },
                                y: {
                                    min: 0, max: 5,
                                    grid: { color: '#f1f5f9' },
                                    title: { display: true, text: 'Mean Score', font: { size: 11 } },
                                    ticks: { stepSize: 1 }
                                }
                            }
                        },
                        plugins: [{
                            id: 'barLabels',
                            afterDatasetsDraw: function(chart) {
                                var ctx2 = chart.ctx;
                                chart.data.datasets[0].data.forEach(function(val, i) {
                                    var meta = chart.getDatasetMeta(0).data[i];
                                    ctx2.fillStyle = '#64748b';
                                    ctx2.font = '11px -apple-system, sans-serif';
                                    ctx2.textAlign = 'center';
                                    ctx2.fillText('n=' + bd.counts[i], meta.x, meta.y - 6);
                                });
                            }
                        }]
                    });
                });
            }

            // --- Interaction heatmap (Chart.js matrix) ---
            if (d.has_interaction) {
                var inter = d.interaction;
                var matrixData = [];
                for (var ri = 0; ri < inter.row_values.length; ri++) {
                    for (var ci = 0; ci < inter.col_values.length; ci++) {
                        var v = inter.means[ri][ci];
                        matrixData.push({
                            x: inter.col_values[ci],
                            y: inter.row_values[ri],
                            v: v,
                            count: inter.counts[ri][ci]
                        });
                    }
                }

                function scoreColor(val) {
                    if (val === null) return 'rgba(226,232,240,0.5)';
                    var t = Math.max(0, Math.min(1, (val - 1) / 4));
                    var r, g, b;
                    if (t < 0.5) {
                        var s = t * 2;
                        r = 239 + (251 - 239) * s;
                        g = 68 + (191 - 68) * s;
                        b = 68 + (36 - 68) * s;
                    } else {
                        var s = (t - 0.5) * 2;
                        r = 251 + (34 - 251) * s;
                        g = 191 + (197 - 191) * s;
                        b = 36 + (94 - 36) * s;
                    }
                    // Soften
                    var mix = 0.25;
                    r = Math.round(r + (255 - r) * mix);
                    g = Math.round(g + (255 - g) * mix);
                    b = Math.round(b + (255 - b) * mix);
                    return 'rgb(' + r + ',' + g + ',' + b + ')';
                }

                var nCols = inter.col_values.length;
                var nRows = inter.row_values.length;

                new Chart(document.getElementById('interactionChart-' + oracleName), {
                    type: 'matrix',
                    data: {
                        datasets: [{
                            label: 'Mean Score',
                            data: matrixData,
                            backgroundColor: function(ctx) {
                                return scoreColor(ctx.raw && ctx.raw.v);
                            },
                            borderColor: 'rgba(255,255,255,0.8)',
                            borderWidth: 3,
                            borderRadius: 6,
                            width: function(ctx) {
                                var a = ctx.chart.chartArea;
                                return a ? (a.width / nCols) - 6 : 40;
                            },
                            height: function(ctx) {
                                var a = ctx.chart.chartArea;
                                return a ? (a.height / nRows) - 6 : 40;
                            }
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                displayColors: false,
                                callbacks: {
                                    title: function(items) {
                                        var raw = items[0].raw;
                                        return raw.y + ' \u00d7 ' + raw.x;
                                    },
                                    label: function(item) {
                                        var raw = item.raw;
                                        if (raw.v === null) return 'No data';
                                        return 'Mean score: ' + raw.v.toFixed(2) + '  (n=' + raw.count + ')';
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                type: 'category',
                                labels: inter.col_values,
                                offset: true,
                                grid: { display: false },
                                ticks: { font: { size: 12, weight: '600' }, color: '#475569' }
                            },
                            y: {
                                type: 'category',
                                labels: inter.row_values,
                                offset: true,
                                reverse: true,
                                grid: { display: false },
                                ticks: { font: { size: 12, weight: '600' }, color: '#475569' }
                            }
                        }
                    },
                    plugins: []
                });
            }
        });
    })();
    </script>
</body>
</html>
